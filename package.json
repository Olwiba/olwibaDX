{
  "name": "@olwiba/dx",
  "version": "0.0.9",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Developer experience tooling for the Olwiba ecosystem",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dx": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": {
      "import": "./dist/eslint.js",
      "types": "./dist/eslint.d.ts"
    },
    "./skills": {
      "import": "./dist/skills.js",
      "types": "./dist/skills.d.ts"
    },
    "./generate-previews": {
      "import": "./dist/generate-previews.js",
      "types": "./dist/generate-previews.d.ts"
    },
    "./ascii": {
      "import": "./dist/ascii/index.js",
      "types": "./dist/ascii/index.d.ts"
    },
    "./ascii-gif": {
      "import": "./dist/ascii-gif.js",
      "types": "./dist/ascii-gif.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "eslint": "^9.0.0",
    "puppeteer-core": "^24.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "puppeteer-core": ">=22.0.0",
    "@typescript-eslint/eslint-plugin": ">=8.0.0",
    "@typescript-eslint/parser": ">=8.0.0",
    "eslint-plugin-react-hooks": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/eslint-plugin": {
      "optional": true
    },
    "@typescript-eslint/parser": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "puppeteer-core": {
      "optional": true
    }
  },
  "homepage": "https://github.com/Olwiba/olwibaDX#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Olwiba/olwibaDX"
  },
  "bugs": {
    "url": "https://github.com/Olwiba/olwibaDX/issues"
  },
  "keywords": [
    "olwiba",
    "dx",
    "developer-experience",
    "vite-plugin",
    "tsup",
    "dev-banner",
    "ascii",
    "figlet",
    "eslint-config"
  ],
  "author": "Olwiba",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
